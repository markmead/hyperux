---
import { type CollectionEntry, getCollection, render } from 'astro:content'

import PatternPost from '../../layouts/PatternPost.astro'

export async function getStaticPaths() {
  return (await getCollection('patterns')).map((pattern: CollectionEntry<'patterns'>) => ({
    params: { slug: pattern.data.slug },
    props: pattern,
  }))
}

type Props = CollectionEntry<'patterns'>

const collection = Astro.props

const { Content } = await render(collection)
---

<PatternPost {...collection.data}>
  <Content />
</PatternPost>
