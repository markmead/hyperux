                      x-bind:aria-controls="listboxId"
                      x-bind:aria-activedescendant="activeDescendantId"
                      type="text"
                      placeholder="Search links and actions..."
                      role="combobox"
                      aria-autocomplete="list"
                      aria-haspopup="listbox"
                      autocomplete="off"
                      class="w-full rounded-md border border-gray-300 px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:outline-none"
                      x-on:input="onInputChange()"
                      x-on:keydown.down.prevent="if (searchQuery.trim() === '') return; if (!isOpen) { openList(); focusedIndex = filteredOptionItems.length > 0 ? 0 : -1; return } focusNextOptionItem()"
                      x-on:keydown.up.prevent="if (searchQuery.trim() === '') return; focusPreviousOptionItem()"
                      x-on:keydown.enter.prevent="
                            const focusedOptionItem = filteredOptionItems[focusedIndex];
                            if (!focusedOptionItem) return;
                            toggleOptionItem(focusedOptionItem.optionItem);
                            const selectedItem = selectItem(focusedOptionItem.optionItem.value);
                            if (selectedItem) { closeList(); $dispatch('hux-command-palette:close') }"
                      x-on:keydown.escape.stop.prevent="closeList(); $dispatch('hux-command-palette:close')"
                    />

