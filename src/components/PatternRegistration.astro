          filterState: filterStateSnapshot,
          filteredItems: [...this.filteredItems],
          totalItems: this.sourceItems.length,
          matchesCount: this.filteredItems.length,
          hasPendingUpdate: this.hasPendingUpdate,
          availableValueMap: Object.fromEntries(
            Object.entries(this.availableValueMap).map(([facetName, values]) => [
