---
import huxComboboxSource from './patterns/huxCombobox.js?raw'
import huxCommandPaletteSource from './patterns/huxCommandPalette.js?raw'
import huxCopySource from './patterns/huxCopy.js?raw'
import huxDialogSource from './patterns/huxDialog.js?raw'
import huxInlineEditorSource from './patterns/huxInlineEditor.js?raw'
import huxDropdownSource from './patterns/huxDropdown.js?raw'
import huxResizableSource from './patterns/huxResizable.js?raw'
import huxScrollSpySource from './patterns/huxScrollSpy.js?raw'
import huxStepperSource from './patterns/huxStepper.js?raw'
import huxTabsSource from './patterns/huxTabs.js?raw'
import huxInfiniteScrollSource from './patterns/huxInfiniteScroll.js?raw'
import huxTabPanelSource from './patterns/huxTabPanel.js?raw'
---

<script is:inline data-hux-copy="huxComboboxRegistration" set:html={huxComboboxSource} />

<script
  is:inline
  data-hux-copy="huxCommandPaletteRegistration"
  set:html={huxCommandPaletteSource}
/>

<script is:inline data-hux-copy="huxCopyRegistration" set:html={huxCopySource} />

<script is:inline data-hux-copy="huxDialogRegistration" set:html={huxDialogSource} />

<script is:inline data-hux-copy="huxInlineEditorRegistration" set:html={huxInlineEditorSource} />

<script is:inline data-hux-copy="huxDropdownRegistration" set:html={huxDropdownSource} />

<script is:inline data-hux-copy="huxResizableRegistration" set:html={huxResizableSource} />

<script is:inline data-hux-copy="huxScrollSpyRegistration" set:html={huxScrollSpySource} />

<script is:inline data-hux-copy="huxStepperRegistration" set:html={huxStepperSource} />

<script is:inline data-hux-copy="huxTabsRegistration" set:html={huxTabsSource} />

<script
  is:inline
  data-hux-copy="huxInfiniteScrollRegistration"
  set:html={huxInfiniteScrollSource}
/>

<script is:inline data-hux-copy="huxTabPanelRegistration" set:html={huxTabPanelSource} />
