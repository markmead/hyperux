---
import { ChevronDown } from '@lucide/astro'

interface Props {
  id: string
  title: string
}

const { id, title } = Astro.props
---

<details id={id} open class="group">
  <summary class="inline-flex cursor-pointer items-center gap-2 [&::-webkit-details-marker]:hidden">
    <ChevronDown class="size-6 group-open:rotate-180" />

    <h2 class="text-xl font-semibold">{title}</h2>
  </summary>

  <div class="mt-4 space-y-4 rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <slot />
  </div>
</details>
