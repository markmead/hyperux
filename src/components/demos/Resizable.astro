<div class="prose-demo not-prose relative rounded-lg border border-gray-300 bg-white p-6">
  <span
    class="absolute -top-3 left-6 inline-flex h-6 items-center rounded-full border border-teal-300 bg-teal-100 px-3 text-xs/6 font-semibold tracking-wide text-teal-900 uppercase"
  >
    Demo
  </span>

  <div class="space-y-4">
    <p class="text-gray-700">
      Drag-to-resize container with keyboard nudge controls and breakpoint awareness.
    </p>

    <div
      data-hux-copy="huxResizableDemo"
      x-data="huxResizable({ stopAtLastBreakpoint: true, preventOverflow: false, iframeSrc: '/examples/resizable.html' })"
      class="space-y-3"
    >
      <div class="flex flex-wrap items-center gap-3">
        <div class="flex items-center gap-2">
          <p class="text-sm text-gray-500">Current breakpoint:</p>

          <span
            class="inline-flex items-center rounded-full border px-3 py-1 text-xs font-semibold tracking-wide uppercase"
            x-bind:class="{
                  'border-gray-300 bg-white text-gray-700': activeBreakpoint === 'xs',
                  'border-green-300 bg-green-100 text-green-800': activeBreakpoint === 'sm',
                  'border-blue-300 bg-blue-100 text-blue-800': activeBreakpoint === 'md',
                  'border-purple-300 bg-purple-100 text-purple-800': activeBreakpoint === 'lg',
                  'border-amber-300 bg-amber-100 text-amber-800': activeBreakpoint === 'xl'
                }"
            x-text="activeBreakpoint"
            aria-live="polite"
            aria-label="Current breakpoint"></span>
        </div>

        <p class="text-sm text-gray-500">
          <span x-text="currentWidth" class="font-mono font-medium text-gray-700"></span>px
        </p>
      </div>

      <div class="flex flex-wrap gap-1.5">
        <template x-for="breakpointItem in breakpointItems" x-bind:key="breakpointItem.label">
          <button
            type="button"
            x-on:click="jumpToLabel(breakpointItem.label)"
            class="inline-flex items-center rounded-full border px-3 py-1 text-xs font-semibold tracking-wide uppercase transition-colors"
            x-bind:class="activeBreakpoint === breakpointItem.label
                  ? 'border-blue-500 bg-blue-500 text-white'
                  : 'border-gray-300 bg-white text-gray-700 hover:border-gray-400 hover:bg-gray-50'"
            x-text="breakpointItem.label"></button>
        </template>
      </div>

      <div
        x-ref="resizableContainer"
        class="relative overflow-hidden rounded-lg bg-gray-50 ring-1 ring-gray-300 focus-within:ring-2 focus-within:ring-blue-500"
        x-bind:style="`width: ${currentWidth}px; min-width: ${minWidth}px;`"
      >
        <iframe
          x-ref="iframeEl"
          x-bind:src="iframeSrc"
          class="block w-full border-none"
          style="height: 400px"
          title="Component preview"></iframe>

        <button
          type="button"
          aria-label="Drag to resize"
          class="absolute top-0 right-0 flex h-full w-3 cursor-col-resize items-center justify-center bg-gray-200 transition-colors hover:bg-gray-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 active:bg-gray-400"
          x-on:mousedown="startDrag($event)"
          x-on:touchstart.prevent="startDrag($event)"
          x-on:keydown.right.prevent="nudgeWidth(8)"
          x-on:keydown.left.prevent="nudgeWidth(-8)"
          x-on:keydown.shift.right.prevent="nudgeWidth(32)"
          x-on:keydown.shift.left.prevent="nudgeWidth(-32)"
          x-on:keydown.up.prevent="jumpToBreakpoint('next')"
          x-on:keydown.down.prevent="jumpToBreakpoint('prev')"
          x-on:keydown.home.prevent="jumpToBreakpoint('first')"
          x-on:keydown.end.prevent="jumpToBreakpoint('last')"></button>
      </div>

      <p class="text-xs text-gray-500">
        Focus the drag handle and use arrow keys to resize by keyboard.
      </p>
    </div>

    <hr class="my-8 h-px w-full border-none bg-gray-200" />

    <div class="flex flex-wrap items-center justify-between gap-4">
      <button
        type="button"
        x-data="huxCopy({ sourceNames: ['huxResizableDemo', 'huxResizableRegistration'] })"
        class="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium hover:bg-gray-100"
        x-on:click="copyToClipboard()"
      >
        <span
          aria-live="polite"
          x-text="hasCopied ? 'Copied Alpine.js + HTML' : 'Copy Alpine.js + HTML'"
        >
          Copy Alpine.js + HTML
        </span>
      </button>

      <a
        href="https://github.com/markmead/hyperux/issues/new"
        target="_blank"
        rel="noreferrer"
        class="inline-block text-sky-600 underline underline-offset-2 hover:text-sky-700"
      >
        Found a bug or improvement? Open an issue.
      </a>
    </div>
  </div>
</div>
