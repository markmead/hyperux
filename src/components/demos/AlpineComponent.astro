---
---

<!-- On-page template: reusable pattern card -->
<template id="hux-pattern-card">
  <div class="space-y-2 rounded-lg border border-gray-200 bg-white p-4">
    <div class="flex items-center justify-between gap-2">
      <h3 class="font-semibold text-gray-900" x-text="pattern.title"></h3>
      <span class="shrink-0 rounded-full bg-sky-100 px-2 py-0.5 text-xs font-medium text-sky-700">
        Pattern
      </span>
    </div>
    <p class="text-sm text-gray-600" x-text="pattern.description"></p>
    <a
      class="inline-block text-sm text-sky-600 underline underline-offset-2 hover:text-sky-700"
      x-bind:href="`/patterns/${pattern.slug}`"
      x-text="`Read the ${pattern.title} docs →`"
    ></a>
  </div>
</template>

<div class="relative rounded-lg border border-gray-300 bg-white p-6">
  <span
    class="absolute -top-3 left-6 inline-flex h-6 items-center rounded-full border border-teal-300 bg-teal-100 px-3 text-xs/6 font-semibold tracking-wide text-teal-900 uppercase"
  >
    Demo
  </span>

  <div class="space-y-8">
    <div class="space-y-4">
      <p class="text-gray-700">
        A single <code>hux-pattern-card</code> template rendered three times via
        <code>x-for</code>, each passing a different <code>pattern</code> object through
        <code>x-data</code>.
      </p>

      <div
        x-data="{
          patterns: [
            {
              title: 'Tabs',
              slug: 'tabs',
              description: 'Accessible tab interfaces with keyboard navigation and optional URL hash sync.'
            },
            {
              title: 'Dialog',
              slug: 'dialog',
              description: 'Focus-trapped modal dialogs with Escape handling and scoped lifecycle events.'
            },
            {
              title: 'Dropdown',
              slug: 'dropdown',
              description: 'Keyboard-friendly action and link menus with focus movement and event dispatch.'
            }
          ]
        }"
        class="grid grid-cols-1 gap-4 sm:grid-cols-3"
      >
        <template x-for="pattern in patterns" x-bind:key="pattern.slug">
          <div
            x-data="{ pattern }"
            x-component="'hux-pattern-card'"
            x-component-styles="global"
          ></div>
        </template>
      </div>
    </div>

    <hr class="h-px w-full border-none bg-gray-200" />

    <div class="space-y-4">
      <p class="text-gray-700">
        A <code>hux-copy-btn</code> component loaded from a URL, using
        <code>huxCopy</code> to copy the code snippet below. The button markup lives in
        <code>/components/hux-copy-btn.html</code> and is reused here via
        <code>x-component.url</code>.
      </p>

      <div
        class="rounded-md border border-dashed border-gray-300 bg-gray-50 p-4 font-mono text-sm text-gray-700"
        data-hux-copy="alpine-component-snippet"
      >
        &lt;div x-data="&#123; pattern &#125;" x-component="'hux-pattern-card'" x-component-styles="global"&gt;&lt;/div&gt;
      </div>

      <div
        x-data="{ copySource: 'alpine-component-snippet', copyLabel: 'Copy snippet' }"
        x-component.url="'/components/hux-copy-btn.html'"
        x-component-styles="global"
      ></div>
    </div>

    <hr class="h-px w-full border-none bg-gray-200" />

    <div class="flex flex-wrap items-center justify-between gap-4">
      <a
        href="https://github.com/markmead/hyperux/issues/new"
        target="_blank"
        rel="noreferrer"
        class="inline-block text-sky-600 underline underline-offset-2 hover:text-sky-700"
      >
        Found a bug or improvement? Open an issue.
      </a>
    </div>
  </div>
</div>
