---

---

<template id="hux-dropdown">
  <div
    x-data="huxDropdown(dropdownConfig)"
    class="relative inline-block"
    x-on:click.window="if (!$event.composedPath().includes($el)) closeMenu()"
  >
    <button
      x-ref="dropdownTrigger"
      x-bind:id="triggerButtonId"
      type="button"
      x-bind:aria-expanded="isOpen.toString()"
      aria-haspopup="menu"
      x-bind:aria-controls="menuId"
      class="inline-flex items-center gap-2 rounded-md border border-gray-300 bg-white px-4 py-2 font-medium transition-colors hover:bg-gray-100"
      x-on:click="toggleMenu()"
      x-on:keydown.down.prevent="openMenu(); focusFirstItem()"
      x-on:keydown.up.prevent="openMenu(); focusLastItem()"
      x-on:keydown.escape.prevent="closeMenu(true)"
      x-on:keydown.tab="if (isOpen) closeMenu()"
    >
      <span x-text="dropdownConfig.triggerLabel"></span>

      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        aria-hidden="true"
        class="size-4 transition-transform"
        x-bind:class="{ 'rotate-180': isOpen }"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"></path>
      </svg>
    </button>

    <div
      x-cloak
      x-show="isOpen"
      x-transition
      x-bind:id="menuId"
      role="menu"
      x-bind:aria-labelledby="triggerButtonId"
      class="absolute left-0 z-10 mt-2 min-w-48 overflow-y-auto rounded-md border border-gray-200 bg-white shadow-md"
      x-on:keydown.down.prevent="focusNextItem()"
      x-on:keydown.up.prevent="focusPreviousItem()"
      x-on:keydown.escape.stop.prevent="closeMenu(true)"
      x-on:keydown.home.prevent="focusFirstItem()"
      x-on:keydown.end.prevent="focusLastItem()"
      x-on:keydown.tab="closeMenu()"
    >
      <template x-for="(menuItem, menuIndex) in menuItems" x-bind:key="menuIndex">
        <div role="none">
          <template x-if="menuItem.href">
            <a
              x-bind:id="menuItemIds[menuIndex]"
              x-bind:href="menuItem.href"
              x-bind:target="menuItem.target || null"
              x-bind:rel="menuItem.target === '_blank' ? 'noreferrer' : null"
              x-bind:tabindex="focusedIndex === menuIndex ? '0' : '-1'"
              x-bind:class="{ 'bg-gray-100': focusedIndex === menuIndex }"
              x-bind:style="`padding-left: ${1 + menuItem.itemDepth * 0.75}rem`"
              role="menuitem"
              class="block py-2 pr-4 text-sm text-gray-700 hover:bg-gray-100 focus:bg-gray-100 focus:outline-none"
              x-on:click="selectItem(menuItem)"
              x-on:mouseenter="focusedIndex = menuIndex"
              x-on:focus="focusedIndex = menuIndex"
              x-text="menuItem.label"></a>
          </template>

          <template x-if="!menuItem.href">
            <button
              x-bind:id="menuItemIds[menuIndex]"
              type="button"
              x-bind:tabindex="focusedIndex === menuIndex ? '0' : '-1'"
              x-bind:class="{ 'bg-gray-100': focusedIndex === menuIndex }"
              x-bind:style="`padding-left: ${1 + menuItem.itemDepth * 0.75}rem`"
              role="menuitem"
              class="block w-full py-2 pr-4 text-left text-sm text-gray-700 hover:bg-gray-100 focus:bg-gray-100 focus:outline-none"
              x-on:click="selectItem(menuItem)"
              x-on:mouseenter="focusedIndex = menuIndex"
              x-on:focus="focusedIndex = menuIndex"
              x-text="menuItem.label"></button>
          </template>
        </div>
      </template>
    </div>
  </div>
</template>

<template id="hux-command-palette">
  <div
    x-data="(() => {
      const dialogComponent = huxDialog({ dialogId: paletteConfig.paletteId })
      const paletteComponent = huxCommandPalette(paletteConfig)
      return {
        ...dialogComponent,
        ...paletteComponent,
        dialogIsOpen: false,
        init() {
          dialogComponent.init.call(this)
          paletteComponent.init.call(this)
        },
        openDialog() {
          this.isOpen = true
          this.dialogIsOpen = true
          this.dispatchDialogEvent('open')
        },
        closeDialog() {
          this.isOpen = false
          this.dialogIsOpen = false
          this.dispatchDialogEvent('close')
        },
      }
    })()"
    x-on:keydown.window="handleGlobalShortcut($event)"
    x-on:hux-command-palette:close.window="closeDialog()"
  >
    <div class="space-y-2">
      <button
        type="button"
        class="rounded-md border border-gray-300 bg-white px-4 py-2 font-medium transition-colors hover:bg-gray-100"
        x-on:click="openDialog()"
        x-text="paletteConfig.buttonLabel || 'Open Command Palette'"></button>

      <p class="text-sm text-gray-600">
        Press <span class="font-medium" x-text="shortcutHint"></span> to open from anywhere.
      </p>
    </div>

    <div
      x-cloak
      x-show="isOpen"
      class="fixed inset-0 z-50 overflow-y-auto"
      x-on:keydown.escape.stop="handleEscape()"
    >
      <div class="flex min-h-full items-start justify-center p-4 pt-24">
        <div
          x-cloak
          x-show="isOpen"
          x-transition.opacity.duration.200ms
          class="fixed inset-0 bg-gray-900/60"
          aria-hidden="true"
          x-on:click="handleBackdropClick()"
        >
        </div>

        <div
          x-cloak
          x-show="isOpen"
          x-trap.noscroll="isOpen"
          x-transition.duration.200ms
          x-bind:aria-labelledby="dialogTitleId || null"
          role="dialog"
          aria-modal="true"
          class="relative w-full max-w-xl space-y-4 rounded-lg bg-white p-4 shadow-xl"
        >
          <h3 x-bind:id="dialogTitleId || null" class="sr-only">Command palette</h3>

          <div
            x-data="{
              ...huxCombobox({
                optionItems: paletteItems.map((paletteItem) => ({ label: paletteItem.label, value: paletteItem.label })),
                inputTemplateRef: 'commandPaletteInput',
                listboxTemplateRef: 'commandPaletteListbox',
                hideOptionItemsWhenSearchQueryEmpty: !paletteConfig.comboboxConfig?.showAllItemsOnOpen
              }),
              get filteredOptionItems() {
                const normalizedOptionItems = Array.isArray(this.optionItems) ? this.optionItems : []
                const normalizedSearchQuery = this.searchQuery.trim().toLowerCase()
                if (this.shouldHideOptionItemsOnEmptyQuery() && normalizedSearchQuery === '') {
                  return []
                }
                return normalizedOptionItems
                  .map((optionItem, sourceIndex) => ({ optionItem, sourceIndex }))
                  .filter(({ optionItem }) => optionItem.label.toLowerCase().includes(normalizedSearchQuery))
              },
              shouldHideOptionItemsOnEmptyQuery() {
                return this.clearSelectionOnInputClear || this.hideOptionItemsWhenSearchQueryEmpty
              },
              get activeDescendantId() {
                if (!this.isOpen || this.focusedIndex < 0) return null
                const focusedOptionItem = this.filteredOptionItems[this.focusedIndex]
                if (!focusedOptionItem) return null
                return this.optionItemId(focusedOptionItem.sourceIndex)
              },
              init() {
                this.configureTemplateRefs()
                this.$watch('dialogIsOpen', (isDialogOpen) => {
                  if (isDialogOpen) {
                    this.onPaletteOpen()
                  } else {
                    this.onPaletteClose()
                  }
                })
              },
              onPaletteOpen() {
                this.searchQuery = ''
                this.focusedIndex = -1
                if (this.shouldHideOptionItemsOnEmptyQuery()) {
                  this.closeList()
                } else {
                  this.openList()
                }
                this.$nextTick(() => this.$refs.commandPaletteInput?.focus())
              },
              onPaletteClose() {
                this.closeList()
                this.clearSelection()
              },
            }"
            class="space-y-2"
          >
            <label x-bind:for="comboboxInputId" class="sr-only">Search links and actions</label>

            <div class="relative">
              <input
                x-ref="commandPaletteInput"
                x-model="searchQuery"
                x-bind:id="comboboxInputId"
                x-bind:aria-expanded="(isOpen && !(shouldHideOptionItemsOnEmptyQuery() && searchQuery.trim() === '')).toString()"
                x-bind:aria-controls="listboxId"
                x-bind:aria-activedescendant="activeDescendantId"
                type="text"
                x-bind:placeholder="paletteConfig.comboboxConfig?.searchPlaceholder || 'Search...'"
                role="combobox"
                aria-autocomplete="list"
                aria-haspopup="listbox"
                autocomplete="off"
                class="w-full rounded-md border border-gray-300 px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:outline-none"
                x-on:input="onInputChange()"
                x-on:keydown.down.prevent="if (shouldHideOptionItemsOnEmptyQuery() && searchQuery.trim() === '') return; if (!isOpen) { openList(); focusedIndex = filteredOptionItems.length > 0 ? 0 : -1; return } focusNextOptionItem()"
                x-on:keydown.up.prevent="if (shouldHideOptionItemsOnEmptyQuery() && searchQuery.trim() === '') return; focusPreviousOptionItem()"
                x-on:keydown.enter.prevent="const focusedOptionItem = filteredOptionItems[focusedIndex]; if (!focusedOptionItem) return; toggleOptionItem(focusedOptionItem.optionItem); const selectedItem = selectItem(focusedOptionItem.optionItem.value); if (selectedItem) { closeList(); $dispatch('hux-command-palette:close') }"
                x-on:keydown.escape.stop.prevent="closeList(); $dispatch('hux-command-palette:close')"
              />

              <div
                x-cloak
                x-transition
                x-show="isOpen && !(shouldHideOptionItemsOnEmptyQuery() && searchQuery.trim() === '')"
                x-ref="commandPaletteListbox"
                x-bind:id="listboxId"
                role="listbox"
                class="mt-2 max-h-72 w-full overflow-y-auto rounded-md border border-gray-300 bg-white"
              >
                <template
                  x-if="filteredOptionItems.length === 0 && !(shouldHideOptionItemsOnEmptyQuery() && searchQuery.trim() === '')"
                >
                  <p class="px-4 py-3 text-gray-500">No results found.</p>
                </template>

                <template
                  x-for="({ optionItem, sourceIndex }, optionIndex) in filteredOptionItems"
                  x-bind:key="`${optionItem.value}-${sourceIndex}`"
                >
                  <button
                    type="button"
                    x-bind:id="optionItemId(sourceIndex)"
                    x-bind:aria-selected="isOptionSelected(optionItem).toString()"
                    x-bind:class="{
                      'bg-blue-100 text-blue-900': focusedIndex === optionIndex,
                      'hover:bg-gray-100': focusedIndex !== optionIndex
                    }"
                    role="option"
                    tabindex="-1"
                    class="flex w-full items-center justify-between gap-3 px-4 py-3 text-left transition-colors"
                    x-on:click="
                      toggleOptionItem(optionItem);
                      const selectedItem = selectItem(optionItem.value);
                      if (selectedItem) {
                        closeList();
                        $dispatch('hux-command-palette:close')
                      }
                    "
                    x-on:mouseenter="focusedIndex = optionIndex"
                  >
                    <span x-text="optionItem.label"></span>

                    <span
                      x-cloak
                      x-data="{ paletteItem: findPaletteItem(optionItem.value) }"
                      x-show="paletteItem"
                      x-bind:class="{
                        'bg-blue-100 text-blue-700': paletteItem?.href && paletteItem?.target !== '_blank',
                        'bg-green-100 text-green-700': paletteItem?.target === '_blank',
                        'bg-purple-100 text-purple-700': paletteItem?.action
                      }"
                      class="shrink-0 rounded-full px-2 py-0.5 text-xs font-medium"
                      x-text="paletteItem?.target === '_blank' ? 'External link' : paletteItem?.href ? 'Internal link' : 'Action'"
                    ></span>
                  </button>
                </template>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<div class="relative rounded-lg border border-gray-300 bg-white p-6">
  <span
    class="absolute -top-3 left-6 inline-flex h-6 items-center rounded-full border border-teal-300 bg-teal-100 px-3 text-xs/6 font-semibold tracking-wide text-teal-900 uppercase"
  >
    Demo
  </span>

  <div class="space-y-8">
    <div class="space-y-4">
      <p class="text-gray-700">
        Two dropdown menus from a single <code>hux-dropdown</code> template. Each host passes a single
        <code>dropdownConfig</code> object; the template calls
        <code>huxDropdown(dropdownConfig)</code> and reads <code>dropdownConfig.triggerLabel</code>
        from the parent scope.
      </p>

      <div class="flex flex-wrap gap-4">
        <div
          x-data="{
            dropdownConfig: {
              triggerId: 'account-menu',
              triggerLabel: 'Account',
              menuItems: [
                { label: 'Profile', href: '/patterns/' },
                { label: 'Settings', href: '/patterns/' },
                { label: 'Sign out', action: 'sign-out' }
              ]
            }
          }"
          x-component="'hux-dropdown'"
          x-component-styles="global"
        >
        </div>

        <div
          x-data="{
            dropdownConfig: {
              triggerId: 'resources-menu',
              triggerLabel: 'Resources',
              menuItems: [
                { label: 'Documentation', href: '/' },
                { label: 'GitHub', href: 'https://github.com/markmead/hyperux', target: '_blank' },
                { label: 'Report a bug', href: 'https://github.com/markmead/hyperux/issues/new', target: '_blank' }
              ]
            }
          }"
          x-component="'hux-dropdown'"
          x-component-styles="global"
        >
        </div>
      </div>
    </div>

    <hr class="h-px w-full border-none bg-gray-200" />

    <div class="space-y-4">
      <p class="text-gray-700">
        Two copy buttons from the same <code>hux-copy-btn</code> URL template. Each host's
        <code>x-data</code> passes a different <code>copyConfig</code> — one uses
        <code>valueSourceNames</code> to copy an input's value, the other uses
        <code>sourceNames</code> to copy a code snippet's markup. The template itself doesn't change.
      </p>

      <div class="space-y-3">
        <label class="block font-medium text-gray-700" for="share-link-input"> Share link </label>

        <div class="flex items-center gap-2">
          <input
            id="share-link-input"
            type="text"
            data-hux-copy="share-link-input"
            value="https://hyperux.dev/patterns/dropdown"
            class="grow rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500"
            readonly
          />

          <div
            x-data="{ copyConfig: { valueSourceNames: ['share-link-input'] }, copyLabel: 'Copy link' }"
            x-component.url="'/components/hux-copy-btn.html'"
            x-component-styles="global"
          >
          </div>
        </div>
      </div>

      <div class="space-y-3">
        <p class="block font-medium text-gray-700">Usage snippet</p>

        <div
          class="rounded-md border border-dashed border-gray-300 bg-gray-50 p-3 font-mono text-sm text-gray-700"
          data-hux-copy="usage-snippet"
        >
          &lt;div x-data="&#123; ... &#125;" x-component="'hux-dropdown'"
          x-component-styles="global"&gt;&lt;/div&gt;
        </div>

        <div
          x-data="{ copyConfig: { sourceNames: ['usage-snippet'] }, copyLabel: 'Copy snippet' }"
          x-component.url="'/components/hux-copy-btn.html'"
          x-component-styles="global"
        >
        </div>
      </div>
    </div>

    <hr class="h-px w-full border-none bg-gray-200" />

    <div class="space-y-4">
      <p class="text-gray-700">
        Two command palettes from a single <code>hux-command-palette</code> template. Each host passes
        a different <code>paletteConfig</code> — including a <code>comboboxConfig</code>
        object that configures the nested <code>huxCombobox</code>. The docs-search palette hides
        results until the user types (<code>showAllItemsOnOpen: false</code>); the actions palette
        shows all items immediately on open (<code>showAllItemsOnOpen: true</code>). The template
        itself doesn't change.
      </p>

      <p class="rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-amber-900">
        <strong>Note:</strong>
        <code>x-teleport</code> cannot be used inside a shadow root — teleported elements lose access
        to the shadow scope. Overlays are rendered inline here; <code>position: fixed</code> still anchors
        them to the viewport.
      </p>

      <div class="flex flex-wrap gap-4">
        <div
          x-data="{
            paletteConfig: {
              paletteId: 'nav-palette',
              shortcutKey: 'p',
              buttonLabel: 'Open Docs Search',
              paletteItems: [
                { label: 'Scroll Spy Docs', href: '/patterns/scroll-spy' },
                { label: 'Copy to Clipboard Docs', href: '/patterns/copy-to-clipboard' },
                { label: 'Combobox Docs', href: '/patterns/combobox' },
                { label: 'Open GitHub', href: 'https://github.com/markmead/hyperux', target: '_blank' }
              ],
              comboboxConfig: {
                searchPlaceholder: 'Type to search docs...',
                showAllItemsOnOpen: false
              }
            }
          }"
          x-component="'hux-command-palette'"
          x-component-styles="global"
        >
        </div>

        <div
          x-data="{
            paletteConfig: {
              paletteId: 'actions-palette',
              shortcutKey: 'b',
              buttonLabel: 'Open Actions',
              paletteItems: [
                { label: 'Dropdown Docs', href: '/patterns/dropdown' },
                { label: 'Dialog Docs', href: '/patterns/dialog' },
                { label: 'Copy page URL', action: 'copy-page-url' }
              ],
              comboboxConfig: {
                searchPlaceholder: 'Browse or filter actions...',
                showAllItemsOnOpen: true
              }
            }
          }"
          x-component="'hux-command-palette'"
          x-component-styles="global"
          x-on:hux-command-palette:actions-palette:copy-page-url.window="navigator.clipboard.writeText(globalThis.location.href).catch(() => {})"
        >
        </div>
      </div>
    </div>
  </div>
</div>
