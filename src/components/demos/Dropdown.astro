<div class="relative rounded-lg border border-gray-300 bg-white p-6">
  <span
    class="absolute -top-3 left-6 inline-flex h-6 items-center rounded-full border border-teal-300 bg-teal-100 px-3 text-xs/6 font-semibold tracking-wide text-teal-900 uppercase"
  >
    Demo
  </span>

  <div class="space-y-4">
    <p class="text-gray-700">
      Dropdown menu behavior with keyboard movement, menu-item focus management, and action
      dispatch.
    </p>

    <div
      x-data="huxDropdown({
        triggerId: 'options-menu',
        menuItems: [
          { label: 'View Profile', href: '#' },
          { label: 'Account Settings', href: '#' },
          { label: 'Documentation', href: 'https://github.com/markmead/hyperux', target: '_blank' },
          { label: 'Copy Page URL', action: 'copyPageUrl' }
        ]
      })"
      class="relative inline-block"
      x-on:click.outside="closeMenu()"
      x-on:hux-dropdown:options-menu:action="(async () => {
          if ($event.detail.action !== 'copyPageUrl') return
          try {
            await navigator.clipboard.writeText(location.href)
          } catch (_) {}
        })()"
    >
      <button
        x-ref="dropdownTrigger"
        x-bind:id="triggerButtonId"
        type="button"
        x-bind:aria-expanded="isOpen.toString()"
        aria-haspopup="menu"
        x-bind:aria-controls="menuId"
        class="inline-flex items-center gap-2 rounded-md border border-gray-300 bg-white px-4 py-2 font-medium transition-colors hover:bg-gray-100"
        x-on:click="toggleMenu()"
        x-on:keydown.down.prevent="openMenu(); focusFirstItem()"
        x-on:keydown.up.prevent="openMenu(); focusLastItem()"
        x-on:keydown.escape.prevent="closeMenu(true)"
        x-on:keydown.tab="if (isOpen) closeMenu()"
      >
        <span>Options</span>

        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
          class="size-4 transition-transform"
          x-bind:class="{ 'rotate-180': isOpen }"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"
          ></path>
        </svg>
      </button>

      <div
        x-cloak
        x-show="isOpen"
        x-transition
        x-bind:id="menuId"
        role="menu"
        x-bind:aria-labelledby="triggerButtonId"
        class="absolute left-0 z-10 mt-2 min-w-48 overflow-hidden rounded-md border border-gray-200 bg-white shadow-md"
        x-on:keydown.down.prevent="focusNextItem()"
        x-on:keydown.up.prevent="focusPreviousItem()"
        x-on:keydown.escape.stop.prevent="closeMenu(true)"
        x-on:keydown.home.prevent="focusFirstItem()"
        x-on:keydown.end.prevent="focusLastItem()"
        x-on:keydown.tab="closeMenu()"
      >
        <template x-for="(menuItem, menuIndex) in menuItems" x-bind:key="menuIndex">
          <div role="none">
            <template x-if="menuItem.href">
              <a
                x-bind:id="menuItemIds[menuIndex]"
                x-bind:href="menuItem.href"
                x-bind:target="menuItem.target || null"
                x-bind:rel="menuItem.target === '_blank' ? 'noreferrer' : null"
                x-bind:tabindex="focusedIndex === menuIndex ? '0' : '-1'"
                x-bind:class="{ 'bg-gray-100': focusedIndex === menuIndex }"
                role="menuitem"
                class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 focus:bg-gray-100 focus:outline-none"
                x-on:click="selectItem(menuItem)"
                x-on:mouseenter="focusedIndex = menuIndex"
                x-on:focus="focusedIndex = menuIndex"
                x-text="menuItem.label"></a>
            </template>

            <template x-if="!menuItem.href">
              <button
                x-bind:id="menuItemIds[menuIndex]"
                type="button"
                x-bind:tabindex="focusedIndex === menuIndex ? '0' : '-1'"
                x-bind:class="{ 'bg-gray-100': focusedIndex === menuIndex }"
                role="menuitem"
                class="block w-full px-4 py-2 text-left text-sm text-gray-700 hover:bg-gray-100 focus:bg-gray-100 focus:outline-none"
                x-on:click="selectItem(menuItem)"
                x-on:mouseenter="focusedIndex = menuIndex"
                x-on:focus="focusedIndex = menuIndex"
                x-text="menuItem.label"></button>
            </template>
          </div>
        </template>
      </div>
    </div>

    <a
      href="https://github.com/markmead/hyperux/issues/new"
      target="_blank"
      rel="noreferrer"
      class="inline-block text-sky-600 underline underline-offset-2 hover:text-sky-700"
    >
      Found a bug or improvement? Open an issue.
    </a>
  </div>
</div>

<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('huxDropdown', (initialConfig = {}) => ({
      isOpen: false,
      focusedIndex: -1,
      menuItems: [],
      triggerId: null,
      menuId: null,
      triggerButtonId: null,
      menuItemIds: [],

      init() {
        this.menuItems = (initialConfig.menuItems ?? []).filter(
          (item) => item?.label && (item?.href || item?.action),
        )

        this.triggerId = initialConfig.triggerId ?? null

        const idSuffix = this.triggerId ?? crypto.randomUUID()

        this.menuId = `hux-dropdown-menu-${idSuffix}`
        this.triggerButtonId = `hux-dropdown-trigger-${idSuffix}`

        this.menuItemIds = this.menuItems.map(
          (_, menuItemIndex) => `${this.menuId}-item-${menuItemIndex}`,
        )
      },

      openMenu() {
        this.isOpen = true
      },

      closeMenu(restoreFocus = false) {
        this.isOpen = false
        this.focusedIndex = -1

        if (restoreFocus) {
          this.$nextTick(() => this.$refs.dropdownTrigger?.focus())
        }
      },

      toggleMenu() {
        if (this.isOpen) {
          this.closeMenu(true)

          return
        }

        this.openMenu()
      },

      focusItem(itemIndex) {
        this.focusedIndex = itemIndex

        this.$nextTick(() => {
          const menuItemElement = document.getElementById(this.menuItemIds[itemIndex])

          menuItemElement?.focus()
        })
      },

      focusFirstItem() {
        if (this.menuItems.length > 0) {
          this.focusItem(0)
        }
      },

      focusLastItem() {
        if (this.menuItems.length > 0) {
          this.focusItem(this.menuItems.length - 1)
        }
      },

      focusNextItem() {
        const menuItemCount = this.menuItems.length

        if (menuItemCount === 0) {
          return
        }

        const nextIndex = this.focusedIndex < menuItemCount - 1 ? this.focusedIndex + 1 : 0

        this.focusItem(nextIndex)
      },

      focusPreviousItem() {
        const menuItemCount = this.menuItems.length

        if (menuItemCount === 0) {
          return
        }

        const prevIndex = this.focusedIndex > 0 ? this.focusedIndex - 1 : menuItemCount - 1

        this.focusItem(prevIndex)
      },

      selectItem(menuItem) {
        if (!menuItem) {
          return
        }

        if (!menuItem.href && menuItem.action) {
          this.$dispatch(
            this.triggerId ? `hux-dropdown:${this.triggerId}:action` : 'hux-dropdown:action',
            { action: menuItem.action, item: menuItem },
          )

          this.closeMenu(true)

          return
        }

        this.closeMenu()
      },
    }))
  })
</script>
