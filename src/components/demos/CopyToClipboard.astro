---
import { Clipboard, CopyCheck } from '@lucide/astro'
---

<div class="prose-demo not-prose relative rounded-lg border border-gray-300 bg-white p-6">
  <span
    class="absolute -top-3 left-6 inline-flex h-6 items-center rounded-full border border-teal-300 bg-teal-100 px-3 text-xs/6 font-semibold tracking-wide text-teal-900 uppercase"
  >
    Demo
  </span>

  <div>
    <div class="space-y-4">
      <div class="prose">
        <p>
          Copying multiple elements with a single button click, including copying the value of an
          input element. This example also demonstrates copying HTML content, which can be useful
          when you want to preserve formatting or include specific markup in the copied content.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <div
          class="rounded-md border border-dashed border-gray-300 bg-gray-50 p-4"
          data-hux-copy="contentExampleA"
        >
          <p class="text-gray-700">
            Lorem ipsum dolor sit amet, consectetur adipisicing elit. Error quaerat obcaecati hic
            exercitationem? Libero unde dolorem est nostrum qui distinctio cum modi minima
            laudantium quia. Itaque consectetur totam adipisci magnam?
          </p>
        </div>

        <div
          class="rounded-md border border-dashed border-gray-300 bg-gray-50 p-4"
          data-hux-copy="contentExampleB"
        >
          <p class="text-gray-700">
            Lorem ipsum dolor sit amet consectetur adipisicing elit. Possimus praesentium quasi
            aliquid molestiae at accusantium veritatis, minima dicta sed voluptatem.
          </p>
        </div>
      </div>

      <button
        type="button"
        x-data="huxCopy({ sourceNames: ['contentExampleA', 'contentExampleB'] })"
        class="inline-flex items-center gap-2 rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium hover:bg-gray-100"
        x-on:click="copyToClipboard()"
      >
        <span
          aria-live="polite"
          x-text="hasCopyFailed ? 'Copy failed' : hasCopied ? 'Copied' : 'Copy'">Copy</span
        >

        <Clipboard x-cloak x-show="!hasCopied" class="size-4" />
        <CopyCheck x-cloak x-show="hasCopied" class="size-4" />
      </button>
    </div>

    <hr class="my-8 h-px w-full border-none bg-gray-200" />

    <div class="space-y-4">
      <div class="prose">
        <p>
          Copying the value of the input below by referencing its data-hux-copy name in the
          valueSourceNames configuration. This allows you to copy dynamic content that may not be
          present in the DOM as text, such as user input or values generated by JavaScript.
        </p>
      </div>

      <label for="hux-copy-input-demo" class="sr-only"> Text to copy </label>

      <div class="relative inline-flex">
        <input
          id="hux-copy-input-demo"
          data-hux-copy="inputExample"
          type="text"
          value="Hello there 👋"
          class="h-10 rounded-md border-gray-300"
        />

        <button
          type="button"
          x-data="huxCopy({ valueSourceNames: ['inputExample'] })"
          aria-label="Copy input value"
          class="absolute top-1 right-1 grid size-8 place-content-center rounded text-gray-700 transition-colors before:absolute before:-inset-1.5 before:content-[''] hover:bg-gray-100"
          x-bind:class="{ 'bg-gray-100': hasCopied }"
          x-on:click="copyToClipboard()"
        >
          <span
            aria-live="polite"
            class="sr-only"
            x-text="hasCopyFailed ? 'Copy failed' : hasCopied ? 'Copied input value' : 'Copy input value'"
            >Copy input value</span
          >

          <Clipboard x-cloak x-show="!hasCopied" class="size-4" />
          <CopyCheck x-cloak x-show="hasCopied" class="size-4" />
        </button>
      </div>
    </div>

    <hr class="my-8 h-px w-full border-none bg-gray-200" />

    <div class="flex flex-wrap items-center justify-between gap-4">
      <button
        type="button"
        x-data="huxCopy({ sourceNames: ['huxCopyRegistration'] })"
        class="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium hover:bg-gray-100"
        x-on:click="copyToClipboard()"
      >
        <span
          aria-live="polite"
          x-text="hasCopyFailed ? 'Copy failed' : hasCopied ? 'Copied Alpine.js' : 'Copy Alpine.js'"
        >
          Copy Alpine.js
        </span>
      </button>

      <a
        href="https://github.com/markmead/hyperux/issues/new"
        target="_blank"
        rel="noreferrer"
        class="inline-block text-sky-600 underline underline-offset-2 hover:text-sky-700"
      >
        Found a bug or improvement? Open an issue.
      </a>
    </div>
  </div>
</div>
