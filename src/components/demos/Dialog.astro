<div class="prose-demo relative rounded-lg border border-gray-300 bg-white p-6">
  <span
    class="absolute -top-3 left-6 inline-flex h-6 items-center rounded-full border border-teal-300 bg-teal-100 px-3 text-xs/6 font-semibold tracking-wide text-teal-900 uppercase"
  >
    Demo
  </span>

  <div class="space-y-4">
    <p class="text-gray-700">
      Focus-trapped modal dialog with Escape handling, optional backdrop, and scoped open/close
      events.
    </p>

    <div data-hux-copy="huxDialogDemo" x-data="huxDialog({ dialogId: 'delete-item-dialog' })">
      <button
        type="button"
        class="rounded-md border border-gray-300 bg-white px-4 py-2 font-medium transition-colors hover:bg-gray-100"
        x-on:click="openDialog()"
      >
        Open Dialog
      </button>

      <template x-teleport="body">
        <div
          x-cloak
          x-show="isOpen"
          class="fixed inset-0 z-50 overflow-y-auto"
          x-on:keydown.escape.stop="handleEscape()"
        >
          <div class="flex min-h-full items-center justify-center p-4">
            <template x-if="showBackdrop">
              <div
                x-cloak
                x-show="isOpen"
                x-transition.opacity.duration.200ms
                class="fixed inset-0 bg-gray-900/60"
                aria-hidden="true"
                x-on:click="handleBackdropClick()"
              >
              </div>
            </template>

            <div
              x-cloak
              x-show="isOpen"
              x-trap.noscroll="isOpen"
              x-transition.duration.200ms
              x-bind:aria-labelledby="dialogTitleId || null"
              role="dialog"
              aria-modal="true"
              class="relative w-full max-w-md space-y-4 rounded-lg bg-white p-6 shadow-xl"
            >
              <div class="flex items-start justify-between gap-4">
                <h3 x-bind:id="dialogTitleId || null" class="text-base font-semibold">
                  Delete item
                </h3>

                <button
                  type="button"
                  class="shrink-0 rounded-md text-gray-400 hover:text-gray-500 focus:ring-2 focus:ring-blue-500 focus:outline-none"
                  aria-label="Close dialog"
                  x-on:click="closeDialog()"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                    class="size-5"
                  >
                    <path
                      d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z"
                    ></path>
                  </svg>
                </button>
              </div>

              <p class="text-gray-600">
                Are you sure you want to delete this item? This action cannot be undone.
              </p>

              <div class="flex justify-end gap-3">
                <button
                  type="button"
                  class="rounded-md border border-gray-300 bg-white px-4 py-2 font-medium transition-colors hover:bg-gray-100"
                  x-on:click="closeDialog()"
                >
                  Cancel
                </button>

                <button
                  type="button"
                  class="rounded-md bg-red-600 px-4 py-2 font-medium text-white transition-colors hover:bg-red-700"
                  x-on:click="closeDialog()"
                >
                  Delete
                </button>
              </div>
            </div>
          </div>
        </div>
      </template>
    </div>

    <hr class="my-8 h-px w-full border-none bg-gray-200" />

    <div class="flex flex-wrap items-center justify-between gap-4">
      <button
        type="button"
        x-data="huxCopy({ sourceNames: ['huxDialogDemo', 'huxDialogRegistration'] })"
        class="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium hover:bg-gray-100"
        x-on:click="copyToClipboard()"
      >
        <span
          aria-live="polite"
          x-text="hasCopied ? 'Copied Alpine.js + HTML' : 'Copy Alpine.js + HTML'"
        >
          Copy Alpine.js + HTML
        </span>
      </button>

      <a
        href="https://github.com/markmead/hyperux/issues/new"
        target="_blank"
        rel="noreferrer"
        class="inline-block text-sky-600 underline underline-offset-2 hover:text-sky-700"
      >
        Found a bug or improvement? Open an issue.
      </a>
    </div>
  </div>
</div>
