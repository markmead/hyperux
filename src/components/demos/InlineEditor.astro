<div class="relative rounded-lg border border-gray-300 bg-white p-6">
  <span
    class="absolute -top-3 left-6 inline-flex h-6 items-center rounded-full border border-teal-300 bg-teal-100 px-3 text-xs/6 font-semibold tracking-wide text-teal-900 uppercase"
  >
    Demo
  </span>

  <div class="space-y-4">
    <p class="text-gray-700">
      Website-style Edit profile section with multiple inline editors. Each row supports focus
      trapping while active, Enter to save, and Escape to cancel.
    </p>

    <section
      data-hux-copy="huxInlineEditorDemo"
      class="space-y-5 rounded-md border border-dashed border-gray-300 bg-gray-50 p-4"
    >
      <header
        class="flex flex-wrap items-center justify-between gap-3 border-b border-gray-200 pb-4"
      >
        <div>
          <h3 class="text-lg font-semibold text-gray-900">Edit profile</h3>
          <p class="text-sm text-gray-500">Update the public details shown on your profile page.</p>
        </div>

        <span
          class="inline-flex items-center rounded-full bg-emerald-50 px-3 py-1 text-xs font-medium text-emerald-700"
        >
          Changes save instantly in this demo
        </span>
      </header>

      <div class="grid gap-4 md:grid-cols-2">
        <div
          x-data="huxInlineEditor({ editorId: 'profile-display-name', inputValue: 'Ada Lovelace', returnFocusTemplateRef: 'displayNameTrigger' })"
          class="rounded-md border border-gray-200 bg-white p-4"
        >
          <p class="text-xs font-semibold tracking-wide text-gray-500 uppercase">Display name</p>

          <div x-cloak x-show="!isEditing" class="mt-2 flex flex-wrap items-center gap-3">
            <p class="text-base font-semibold text-gray-900" x-text="inputValue"></p>

            <button
              type="button"
              x-ref="displayNameTrigger"
              class="rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium hover:bg-gray-100"
              x-on:click="enterEditMode()"
            >
              Edit
            </button>
          </div>

          <div
            x-cloak
            x-show="isEditing"
            x-ref="inlineEditor"
            class="mt-2 flex flex-wrap items-center gap-2"
            x-on:keydown="trapFocus($event)"
          >
            <label for="profile-display-name-inline-editor" class="sr-only">Display name</label>

            <input
              id="profile-display-name-inline-editor"
              x-ref="inlineEditorInput"
              x-model="draftValue"
              type="text"
              x-init="registerInput($el)"
              class="min-w-0 flex-1 rounded-md border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none"
              x-on:focus="handleInputFocus($event)"
              x-on:keydown="handleInputKeydown($event)"
            />

            <button
              type="button"
              class="rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700"
              x-on:click="commitChanges()"
            >
              Save
            </button>

            <button
              type="button"
              class="rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium hover:bg-gray-100"
              x-on:click="revertChanges()"
            >
              Cancel
            </button>
          </div>
        </div>

        <div
          x-data="huxInlineEditor({ editorId: 'profile-headline', inputValue: 'Mathematician and analytical engine enthusiast', returnFocusTemplateRef: 'headlineTrigger' })"
          class="rounded-md border border-gray-200 bg-white p-4"
        >
          <p class="text-xs font-semibold tracking-wide text-gray-500 uppercase">Headline</p>

          <div x-cloak x-show="!isEditing" class="mt-2 flex flex-wrap items-center gap-3">
            <p class="text-sm text-gray-900" x-text="inputValue"></p>

            <button
              type="button"
              x-ref="headlineTrigger"
              class="rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium hover:bg-gray-100"
              x-on:click="enterEditMode()"
            >
              Edit
            </button>
          </div>

          <div
            x-cloak
            x-show="isEditing"
            x-ref="inlineEditor"
            class="mt-2 flex flex-wrap items-center gap-2"
            x-on:keydown="trapFocus($event)"
          >
            <label for="profile-headline-inline-editor" class="sr-only">Headline</label>

            <input
              id="profile-headline-inline-editor"
              x-ref="inlineEditorInput"
              x-model="draftValue"
              type="text"
              x-init="registerInput($el)"
              class="min-w-0 flex-1 rounded-md border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none"
              x-on:focus="handleInputFocus($event)"
              x-on:keydown="handleInputKeydown($event)"
            />

            <button
              type="button"
              class="rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700"
              x-on:click="commitChanges()"
            >
              Save
            </button>

            <button
              type="button"
              class="rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium hover:bg-gray-100"
              x-on:click="revertChanges()"
            >
              Cancel
            </button>
          </div>
        </div>

        <div
          x-data="huxInlineEditor({ editorId: 'profile-location', inputValue: 'London, United Kingdom', returnFocusTemplateRef: 'locationTrigger' })"
          class="rounded-md border border-gray-200 bg-white p-4"
        >
          <p class="text-xs font-semibold tracking-wide text-gray-500 uppercase">Location</p>

          <div x-cloak x-show="!isEditing" class="mt-2 flex flex-wrap items-center gap-3">
            <p class="text-sm text-gray-900" x-text="inputValue"></p>

            <button
              type="button"
              x-ref="locationTrigger"
              class="rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium hover:bg-gray-100"
              x-on:click="enterEditMode()"
            >
              Edit
            </button>
          </div>

          <div
            x-cloak
            x-show="isEditing"
            x-ref="inlineEditor"
            class="mt-2 flex flex-wrap items-center gap-2"
            x-on:keydown="trapFocus($event)"
          >
            <label for="profile-location-inline-editor" class="sr-only">Location</label>

            <input
              id="profile-location-inline-editor"
              x-ref="inlineEditorInput"
              x-model="draftValue"
              type="text"
              x-init="registerInput($el)"
              class="min-w-0 flex-1 rounded-md border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none"
              x-on:focus="handleInputFocus($event)"
              x-on:keydown="handleInputKeydown($event)"
            />

            <button
              type="button"
              class="rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700"
              x-on:click="commitChanges()"
            >
              Save
            </button>

            <button
              type="button"
              class="rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium hover:bg-gray-100"
              x-on:click="revertChanges()"
            >
              Cancel
            </button>
          </div>
        </div>

        <div
          x-data="huxInlineEditor({ editorId: 'profile-website', inputValue: 'https://example.com/ada', returnFocusTemplateRef: 'websiteTrigger' })"
          class="rounded-md border border-gray-200 bg-white p-4"
        >
          <p class="text-xs font-semibold tracking-wide text-gray-500 uppercase">Website</p>

          <div x-cloak x-show="!isEditing" class="mt-2 flex flex-wrap items-center gap-3">
            <p class="text-sm text-gray-900" x-text="inputValue"></p>

            <button
              type="button"
              x-ref="websiteTrigger"
              class="rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium hover:bg-gray-100"
              x-on:click="enterEditMode()"
            >
              Edit
            </button>
          </div>

          <div
            x-cloak
            x-show="isEditing"
            x-ref="inlineEditor"
            class="mt-2 flex flex-wrap items-center gap-2"
            x-on:keydown="trapFocus($event)"
          >
            <label for="profile-website-inline-editor" class="sr-only">Website</label>

            <input
              id="profile-website-inline-editor"
              x-ref="inlineEditorInput"
              x-model="draftValue"
              type="url"
              x-init="registerInput($el)"
              class="min-w-0 flex-1 rounded-md border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none"
              x-on:focus="handleInputFocus($event)"
              x-on:keydown="handleInputKeydown($event)"
            />

            <button
              type="button"
              class="rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700"
              x-on:click="commitChanges()"
            >
              Save
            </button>

            <button
              type="button"
              class="rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium hover:bg-gray-100"
              x-on:click="revertChanges()"
            >
              Cancel
            </button>
          </div>
        </div>

        <div
          x-data="huxInlineEditor({ editorId: 'profile-username', inputValue: '@ada-lovelace', returnFocusTemplateRef: 'usernameTrigger' })"
          class="rounded-md border border-gray-200 bg-white p-4"
        >
          <p class="text-xs font-semibold tracking-wide text-gray-500 uppercase">Username</p>

          <div x-cloak x-show="!isEditing" class="mt-2 flex flex-wrap items-center gap-3">
            <p class="text-sm text-gray-900" x-text="inputValue"></p>

            <button
              type="button"
              x-ref="usernameTrigger"
              class="rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium hover:bg-gray-100"
              x-on:click="enterEditMode()"
            >
              Edit
            </button>
          </div>

          <div
            x-cloak
            x-show="isEditing"
            x-ref="inlineEditor"
            class="mt-2 flex flex-wrap items-center gap-2"
            x-on:keydown="trapFocus($event)"
          >
            <label for="profile-username-inline-editor" class="sr-only">Username</label>

            <input
              id="profile-username-inline-editor"
              x-ref="inlineEditorInput"
              x-model="draftValue"
              type="text"
              x-init="registerInput($el)"
              class="min-w-0 flex-1 rounded-md border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none"
              x-on:focus="handleInputFocus($event)"
              x-on:keydown="handleInputKeydown($event)"
            />

            <button
              type="button"
              class="rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700"
              x-on:click="commitChanges()"
            >
              Save
            </button>

            <button
              type="button"
              class="rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium hover:bg-gray-100"
              x-on:click="revertChanges()"
            >
              Cancel
            </button>
          </div>
        </div>

        <div
          x-data="huxInlineEditor({ editorId: 'profile-pronouns', inputValue: 'she/her', returnFocusTemplateRef: 'pronounsTrigger' })"
          class="rounded-md border border-gray-200 bg-white p-4"
        >
          <p class="text-xs font-semibold tracking-wide text-gray-500 uppercase">Pronouns</p>

          <div x-cloak x-show="!isEditing" class="mt-2 flex flex-wrap items-center gap-3">
            <p class="text-sm text-gray-900" x-text="inputValue"></p>

            <button
              type="button"
              x-ref="pronounsTrigger"
              class="rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium hover:bg-gray-100"
              x-on:click="enterEditMode()"
            >
              Edit
            </button>
          </div>

          <div
            x-cloak
            x-show="isEditing"
            x-ref="inlineEditor"
            class="mt-2 flex flex-wrap items-center gap-2"
            x-on:keydown="trapFocus($event)"
          >
            <label for="profile-pronouns-inline-editor" class="sr-only">Pronouns</label>

            <input
              id="profile-pronouns-inline-editor"
              x-ref="inlineEditorInput"
              x-model="draftValue"
              type="text"
              x-init="registerInput($el)"
              class="min-w-0 flex-1 rounded-md border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none"
              x-on:focus="handleInputFocus($event)"
              x-on:keydown="handleInputKeydown($event)"
            />

            <button
              type="button"
              class="rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700"
              x-on:click="commitChanges()"
            >
              Save
            </button>

            <button
              type="button"
              class="rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium hover:bg-gray-100"
              x-on:click="revertChanges()"
            >
              Cancel
            </button>
          </div>
        </div>
      </div>
    </section>

    <hr class="my-8 h-px w-full border-none bg-gray-200" />

    <div class="flex flex-wrap items-center justify-between gap-4">
      <button
        type="button"
        x-data="huxCopy({ sourceNames: ['huxInlineEditorDemo', 'huxInlineEditorRegistration'] })"
        class="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium hover:bg-gray-100"
        x-on:click="copyToClipboard()"
      >
        <span
          aria-live="polite"
          x-text="hasCopied ? 'Copied Alpine.js + HTML' : 'Copy Alpine.js + HTML'"
        >
          Copy Alpine.js + HTML
        </span>
      </button>

      <a
        href="https://github.com/markmead/hyperux/issues/new"
        target="_blank"
        rel="noreferrer"
        class="inline-block text-sky-600 underline underline-offset-2 hover:text-sky-700"
      >
        Found a bug or improvement? Open an issue.
      </a>
    </div>
  </div>
</div>
