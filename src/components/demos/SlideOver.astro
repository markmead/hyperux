<div
  class="prose-demo not-prose prose-demo not-prose relative rounded-lg border border-gray-300 bg-white p-6"
>
  <span
    class="absolute -top-3 left-6 inline-flex h-6 items-center rounded-full border border-teal-300 bg-teal-100 px-3 text-xs/6 font-semibold tracking-wide text-teal-900 uppercase"
  >
    Demo
  </span>

  <div class="space-y-4">
    <p class="text-gray-700">
      Focus-trapped slide-over panel built with <code>huxDialog</code>, using CSS transitions for
      the slide animation and edge positioning.
    </p>

    <div data-hux-copy="huxSlideOverDialogDemo" x-data="huxDialog({ dialogId: 'user-settings' })">
      <button
        type="button"
        class="rounded-md border border-gray-300 bg-white px-4 py-2 font-medium transition-colors hover:bg-gray-100"
        x-on:click="openDialog()"
      >
        Open Slide-over
      </button>

      <template x-teleport="body">
        <div
          x-cloak
          x-show="isOpen"
          class="fixed inset-0 z-50"
          x-on:keydown.escape.stop="handleEscape()"
        >
          <div
            x-cloak
            x-show="showBackdrop"
            x-transition.opacity.duration.200ms
            class="fixed inset-0 bg-gray-900/60"
            aria-hidden="true"
            x-on:click="handleBackdropClick()"
          >
          </div>

          <div
            x-cloak
            x-show="isOpen"
            x-trap.noscroll="isOpen"
            x-transition:enter="transform transition-transform duration-300 ease-out"
            x-transition:enter-start="translate-x-full"
            x-transition:enter-end="translate-x-0"
            x-transition:leave="transform transition-transform duration-200 ease-in"
            x-transition:leave-start="translate-x-0"
            x-transition:leave-end="translate-x-full"
            x-bind:aria-labelledby="dialogTitleId || null"
            role="dialog"
            aria-modal="true"
            class="fixed top-0 right-0 h-full w-full max-w-md overflow-y-auto bg-white shadow-xl"
          >
            <div class="flex h-full flex-col">
              <div class="flex items-center justify-between border-b border-gray-200 px-6 py-4">
                <h2 x-bind:id="dialogTitleId || null" class="text-base font-semibold text-gray-900">
                  User Settings
                </h2>

                <button
                  type="button"
                  class="shrink-0 rounded-md text-gray-400 hover:text-gray-500 focus:ring-2 focus:ring-blue-500 focus:outline-none"
                  aria-label="Close slide-over"
                  x-on:click="closeDialog()"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                    class="size-5"
                  >
                    <path
                      d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z"
                    ></path>
                  </svg>
                </button>
              </div>

              <div class="flex-1 space-y-6 overflow-y-auto px-6 py-6">
                <div class="space-y-4">
                  <h3 class="text-sm font-semibold tracking-wide text-gray-500 uppercase">
                    Profile
                  </h3>

                  <div class="space-y-3">
                    <div>
                      <label
                        for="slide-over-display-name"
                        class="mb-1 block text-sm font-medium text-gray-700"
                      >
                        Display name
                      </label>
                      <input
                        id="slide-over-display-name"
                        type="text"
                        placeholder="Your display name"
                        class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none"
                      />
                    </div>

                    <div>
                      <label
                        for="slide-over-email"
                        class="mb-1 block text-sm font-medium text-gray-700"
                      >
                        Email
                      </label>
                      <input
                        id="slide-over-email"
                        type="email"
                        placeholder="you@example.com"
                        class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none"
                      />
                    </div>
                  </div>
                </div>

                <div class="space-y-4">
                  <h3 class="text-sm font-semibold tracking-wide text-gray-500 uppercase">
                    Preferences
                  </h3>

                  <div class="space-y-3">
                    <label class="flex items-center gap-3">
                      <input type="checkbox" class="rounded border-gray-300 text-blue-600" />
                      <span class="text-sm text-gray-700">Email notifications</span>
                    </label>

                    <label class="flex items-center gap-3">
                      <input type="checkbox" class="rounded border-gray-300 text-blue-600" />
                      <span class="text-sm text-gray-700">Marketing updates</span>
                    </label>
                  </div>
                </div>
              </div>

              <div class="flex justify-end gap-3 border-t border-gray-200 px-6 py-4">
                <button
                  type="button"
                  class="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-100"
                  x-on:click="closeDialog()"
                >
                  Cancel
                </button>

                <button
                  type="button"
                  class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-blue-700"
                  x-on:click="closeDialog()"
                >
                  Save changes
                </button>
              </div>
            </div>
          </div>
        </div>
      </template>
    </div>

    <hr class="my-8 h-px w-full border-none bg-gray-200" />

    <div class="flex flex-wrap items-center justify-between gap-4">
      <button
        type="button"
        x-data="huxCopy({ sourceNames: ['huxSlideOverDialogDemo', 'huxDialogRegistration'] })"
        class="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium hover:bg-gray-100"
        x-on:click="copyToClipboard()"
      >
        <span
          aria-live="polite"
          x-text="hasCopied ? 'Copied Alpine.js + HTML' : 'Copy Alpine.js + HTML'"
        >
          Copy Alpine.js + HTML
        </span>
      </button>

      <a
        href="https://github.com/markmead/hyperux/issues/new"
        target="_blank"
        rel="noreferrer"
        class="inline-block text-sky-600 underline underline-offset-2 hover:text-sky-700"
      >
        Found a bug or improvement? Open an issue.
      </a>
    </div>
  </div>
</div>
