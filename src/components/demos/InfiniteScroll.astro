<div class="prose-demo not-prose relative rounded-lg border border-gray-300 bg-white p-6">
  <span
    class="absolute -top-3 left-6 inline-flex h-6 items-center rounded-full border border-teal-300 bg-teal-100 px-3 text-xs/6 font-semibold tracking-wide text-teal-900 uppercase"
  >
    Demo
  </span>

  <div class="space-y-4">
    <div class="prose">
      <p>
        Scroll to the bottom of the list to load more posts. The component fires a
        <code>load-more</code> event; the consumer fetches data and calls
        <code>detail.done(hasMore)</code> when the response arrives. Passing <code>false</code> stops
        the observer once all items are loaded.
      </p>
    </div>

    <p class="font-semibold">Demo Config</p>

    <pre
      class="overflow-x-auto rounded-md bg-gray-800 p-4 text-sm text-gray-100"
    >{`huxInfiniteScroll({ scrollerId: 'posts', containerRoot: true })`}</pre>

    <div
      x-data="{
        posts: [],
        page: 0,
        loadMore(detail) {
          fetch('https://jsonplaceholder.typicode.com/posts?_page=' + (++this.page) + '&_limit=10')
            .then((res) => res.json())
            .then((data) => { this.posts.push(...data); detail.done(data.length > 0) })
            .catch(() => detail.error())
        }
      }"
      x-on:hux-infinite-scroll:posts:load-more.window="loadMore($event.detail)"
    >
      <div
        data-hux-copy="huxInfiniteScrollDemo"
        x-data="huxInfiniteScroll({ scrollerId: 'posts', containerRoot: true })"
        class="max-h-96 divide-y divide-gray-100 overflow-y-auto rounded-md border border-gray-200"
      >
        <template x-for="post in posts" x-bind:key="post.id">
          <div class="px-4 py-3">
            <p class="text-sm font-medium capitalize text-gray-900" x-text="post.title"></p>
            <p class="mt-0.5 line-clamp-2 text-sm text-gray-500" x-text="post.body"></p>
          </div>
        </template>

        <div x-ref="infiniteScrollSentinel" class="h-px" aria-hidden="true"></div>

        <div
          x-show="isLoading"
          x-cloak
          class="px-4 py-3 text-center text-sm text-gray-500"
          aria-live="polite"
        >
          Loading more posts&hellip;
        </div>

        <div x-show="isDisabled" x-cloak class="px-4 py-3 text-center text-sm text-gray-500">
          All posts loaded.
        </div>
      </div>
    </div>

    <hr class="my-8 h-px w-full border-none bg-gray-200" />

    <div class="flex flex-wrap items-center justify-between gap-4">
      <button
        type="button"
        x-data="huxCopy({ sourceNames: ['huxInfiniteScrollDemo', 'huxInfiniteScrollRegistration'] })"
        class="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium hover:bg-gray-100"
        x-on:click="copyToClipboard()"
      >
        <span
          aria-live="polite"
          x-text="hasCopied ? 'Copied Alpine.js + HTML' : 'Copy Alpine.js + HTML'"
        >
          Copy Alpine.js + HTML
        </span>
      </button>

      <a
        href="https://github.com/markmead/hyperux/issues/new"
        target="_blank"
        rel="noreferrer"
        class="inline-block text-sky-600 underline underline-offset-2 hover:text-sky-700"
      >
        Found a bug or improvement? Open an issue.
      </a>
    </div>
  </div>
</div>
